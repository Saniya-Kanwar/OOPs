  Person(string n,int a)
  {
    name =n;
    age = a;
  }
  
  void display()
  {
    cout<<name<<" "<<age<<endl;
  }
 
  
};

// Hierarical inheritance
class Student : public Human
{
  int roll;
  
  public:
  Student(string n,int r)
  {
    name =n;
    roll = r;
  }
  
  void display()
  {
    cout<<name<<" "<<roll<<endl;
  }
};
  
