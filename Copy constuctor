#include <iostream>
using namespace std;

// Copy Constuctor
class Student 
{
  public:
  string name;
  int age;
  int roll_no;
  
  Student(string name,int age,int roll_no)
  {
    this->name = name;
    this->age = age;
    this->roll_no = roll_no;
    cout<<name<<" "<<age<<" "<<roll_no;
  }
  
  // Copy constructor
  Student(Student &a)
  {
    name = a.name;  //here name of obj2 is assigned name of a(obj1)
    age = a.age;
    roll_no = a.roll_no;
    cout<<name<<" "<<age<<" "<<roll_no;
  }
  
  
};

int main() 
{
    Student obj1("Saniya",2,45);
    cout<<endl<<"Copy :"<<endl;
    Student obj2(obj1);
    return 0;
}
