#include <iostream>
using namespace std;

//Encapsulatio/Abstraction
class Student
{
  //properties are private
  string name;
  int age;
  int roll;
  
  public:
  void setter(string n,int a,int r)  // to set data
  {
    name = n;
    age = a;
    roll = r;
  }
  
  int getter()      // to get data
  {
    return age;
  }
  
  void display()
  {
    cout<<name<<" "<<age<<" "<<roll;
  }
  
};

int main() 
{
  Student obj;
  obj.setter("Saniya",20,445);
  cout<<obj.getter()<<endl;
  obj.display();
  return 0;
}
